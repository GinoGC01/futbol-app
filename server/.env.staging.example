# ============================================================
# Variables de entorno del SERVIDOR — Plantilla para STAGING
# ============================================================
# Copiar como .env y completar los valores marcados con <...>
# En Render, configurar estas variables directamente en el Dashboard.
# ============================================================

# --- Servidor ---
PORT=3000
NODE_ENV=staging

# --- Supabase (instancia STAGING) ---
SUPABASE_URL=<URL_DE_SUPABASE_STAGING>
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY_STAGING>
SUPABASE_JWT_SECRET=<JWT_SECRET_DE_SUPABASE_STAGING>

# --- JWT propio de la API ---
JWT_SECRET=<SECRETO_PARA_FIRMAR_TOKENS_JWT>

# --- URLs ---
# URL del frontend (Dashboard Admin) en Vercel staging
APP_URL=https://canchalibre-staging.vercel.app
# URL del frontend para CORS (debe coincidir con APP_URL sin path)
FRONTEND_URL=https://canchalibre-staging.vercel.app
# URL de la landing page
LANDING_URL=https://canchalibre.pro

# --- Emails (Resend) ---
RESEND_API_KEY=<API_KEY_DE_RESEND>
EMAIL_FROM="Cancha Libre <onboarding@canchalibre.pro>"
VERIFICATION_TOKEN_EXPIRES_HOURS=24

# --- Google OAuth ---
GOOGLE_CLIENT_ID=<GOOGLE_OAUTH_CLIENT_ID>

# --- Webhooks & Seguridad ---
SUPABASE_WEBHOOK_SECRET=<SECRETO_COMPARTIDO_PARA_WEBHOOKS>

# --- Administración ---
GMAIL_SUPERADMIN=<EMAIL_DEL_SUPERADMIN>
