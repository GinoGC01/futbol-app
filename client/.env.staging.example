# ============================================================
# Variables de entorno del CLIENTE — Plantilla para STAGING
# ============================================================
# En Vercel, configurar estas variables en:
#   Settings → Environment Variables → Seleccionar entorno "Preview"
# ============================================================

# URL del proyecto de Supabase (instancia STAGING)
VITE_SUPABASE_URL=<URL_DE_SUPABASE_STAGING>

# Clave pública (anon key) de Supabase STAGING
VITE_SUPABASE_ANON_KEY=<ANON_KEY_DE_SUPABASE_STAGING>

# URL base del servidor backend en Render (STAGING)
VITE_API_URL=https://canchalibre-api-staging.onrender.com/api

# URL del frontend para redirecciones internas
VITE_API_DOM=https://canchalibre-staging.vercel.app/

# ID de cliente de Google para autenticación OAuth2
VITE_GOOGLE_CLIENT_ID=<GOOGLE_OAUTH_CLIENT_ID>
