            class="h-14 md:h-20 group-hover:scale-105 transition-transform duration-500"
          />
        </a>
        <p
          class="text-muted text-2xl max-w-lg font-space font-medium leading-relaxed italic mb-10"
        >
          LA PLATAFORMA QUE ESTÁ REVOLUCIONANDO EL <span
            class="text-white font-black">FÚTBOL AMATEUR</span
          > CON TECNOLOGÍA DE ÉLITE.
        </p>

