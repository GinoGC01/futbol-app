      </div>

      <!-- Navigation Links -->
      <div class="lg:col-span-3">
        <h4
          class="text-primary font-display text-4xl mb-10 uppercase italic tracking-tighter"
        >
          NAVEGACIÓN
        </h4>
        <ul class="flex flex-col gap-6 font-space text-muted font-black">
          <li>
            <a
              href="/#como-funciona"
              class="hover:text-white transition-colors uppercase tracking-[0.2em] text-lg flex items-center gap-3"
              ><span class="w-2 h-2 bg-primary rotate-45"></span> CÓMO FUNCIONA</a
            >
          </li>
          <li>
            <a
              href="/#beneficios"
              class="hover:text-white transition-colors uppercase tracking-[0.2em] text-lg flex items-center gap-3"
              ><span class="w-2 h-2 bg-primary rotate-45"></span> BENEFICIOS</a
            >
          </li>
          <li>
            <a
              href="/#precios"
              class="hover:text-white transition-colors uppercase tracking-[0.2em] text-lg flex items-center gap-3"
              ><span class="w-2 h-2 bg-primary rotate-45"></span> PRECIOS</a
            >
          </li>
          <li>
            <a
              href="/#faq"
              class="hover:text-white transition-colors uppercase tracking-[0.2em] text-lg flex items-center gap-3"
              ><span class="w-2 h-2 bg-primary rotate-45"></span> PREGUNTAS</a
            >
          </li>
          <li>
            <a
              href="https://app.canchalibre.pro"
              class="text-primary hover:text-white transition-colors uppercase tracking-[0.2em] text-lg flex items-center gap-3"
              ><span class="w-2 h-2 bg-primary rotate-45 shadow-glow-primary"
              ></span> ENTRAR A LA APP</a
            >
          </li>
        </ul>
      </div>

      <!-- Contact/Status Section -->
      <div class="lg:col-span-4">
        <h4
          class="text-white font-display text-4xl mb-10 uppercase italic tracking-tighter"
        >
          SOPORTE
        </h4>
        <div
          class="glass p-8 rounded-3xl border-white/5 relative overflow-hidden group"
        >
          <div
            class="absolute top-0 right-0 w-24 h-24 bg-primary/5 -translate-y-12 translate-x-12 rotate-45 group-hover:bg-primary/10 transition-colors"
          >
          </div>
          <p
            class="text-muted font-space font-bold mb-4 uppercase tracking-widest text-sm"
          >
            Email de contacto
          </p>
          <a href="mailto:soporte@canchalibre.pro" class="text-white font-display text-3xl mb-8 tracking-tight hover:text-primary transition-colors">
            SOPORTE@CANCHALIBRE.PRO
          </a>

          <div
            class="flex items-center gap-4 py-4 px-6 bg-primary/10 rounded-2xl border border-primary/20"
          >
            <div
              class="w-3 h-3 bg-primary rounded-full animate-pulse shadow-glow-primary"
            >
            </div>
            <span
              class="text-primary font-space font-black text-xs tracking-[0.3em] uppercase"
              >SISTEMAS OPERATIVOS 24/7</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-10"
    >
      <div class="flex flex-col md:flex-row items-center gap-8">
        <p
          class="text-muted/40 font-space text-xs tracking-[0.5em] uppercase font-black"
        >
          © {new Date().getFullYear()} CANCHA LIBRE. DOMINÁ EL POTRERO.
        </p>
        <div class="flex gap-6">
          <a
            href="/privacidad"
            class="text-muted/40 hover:text-white transition-colors text-xs font-black uppercase tracking-widest"
            >Privacidad</a
          >
          <a
            href="/terminos"
            class="text-muted/40 hover:text-white transition-colors text-xs font-black uppercase tracking-widest"
            >Términos</a
          >
          <a
            href="/soporte"
            class="text-muted/40 hover:text-white transition-colors text-xs font-black uppercase tracking-widest"
            >Soporte</a
          >
        </div>
      </div>

      <a
        href="https://www.mariosweb.site/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-6 group cursor-pointer"
      >
        <span
          class="text-xs font-black font-space uppercase tracking-[0.4em] text-muted group-hover:text-primary transition-colors"
          >PRODUCIDO POR</span
        >
        <div
          class="bg-white/5 p-3 rounded-xl border border-white/10 group-hover:border-primary/50 transition-all"
        >
          <img
            src="/images/logo_marios.png"
            alt="Marios Web"
            class="h-8 group-hover:scale-110 transition-transform"
          />
        </div>
      </a>
    </div>
  </div>
</footer>
