---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { id: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="pt-32 pb-20 px-4 min-h-screen">
    <div class="max-w-3xl mx-auto">
      <!-- Back Button -->
      <a 
        href="/blog" 
        class="inline-flex items-center gap-2 text-text-muted hover:text-primary transition-colors font-bold tracking-widest text-xs uppercase group mb-6"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        VOLVER A TODOS LOS POSTS
      </a>

      <!-- Breadcrumbs -->
      <nav
        class="flex items-center gap-2 text-xs font-bold tracking-[0.2em] text-text-muted uppercase mb-8"
      >
        <a href="/" class="hover:text-primary transition-colors">INICIO</a>
        <span>/</span>
        <a href="/blog" class="hover:text-primary transition-colors">BLOG</a>
        <span>/</span>
        <span class="text-primary">{post.data.title}</span>
      </nav>

      <!-- Header -->
      <header class="mb-12 space-y-6">
        <div class="flex items-center flex-wrap gap-4">
          {
            post.data.tags.map((tag: string) => (
              <span class="text-[10px] tracking-[0.2em] font-bold text-primary uppercase bg-primary/10 px-3 py-1 rounded-full border border-primary/20">
                {tag}
              </span>
            ))
          }
          <time class="text-text-muted text-xs font-medium">
            {
              post.data.pubDate.toLocaleDateString("es-ES", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </time>
        </div>

        <h1
          class="text-5xl md:text-7xl font-heading italic text-white leading-[0.9] tracking-tighter"
        >
          {post.data.title}
        </h1>

        <p
          class="text-xl text-text-muted font-subheading leading-relaxed italic border-l-2 border-primary pl-6"
        >
          {post.data.description}
        </p>

        <div class="flex items-center gap-4 pt-4">
          <div
            class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-dark font-bold"
          >
            {post.data.author.charAt(0)}
          </div>
          <div>
            <p class="text-sm font-bold text-white uppercase tracking-wider">
              {post.data.author}
            </p>
            <p class="text-[10px] text-text-muted uppercase tracking-[0.2em]">
              EQUIPO CANCHA LIBRE
            </p>
          </div>
        </div>
      </header>

      <!-- Featured Image -->
      {
        post.data.image && (
          <div class="relative aspect-video rounded-3xl overflow-hidden mb-16 border border-white/5 shadow-2xl">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full h-full object-cover"
              style={`view-transition-name: blog-image-${post.id}`}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark/50 to-transparent" />
          </div>
        )
      }

      <!-- Content -->
      <div
        class="prose prose-invert prose-primary max-w-none
				prose-headings:font-heading prose-headings:italic prose-headings:tracking-tight
				prose-h1:text-5xl prose-h2:text-4xl prose-h3:text-3xl
				prose-p:text-text-muted prose-p:text-lg prose-p:leading-relaxed
				prose-li:text-text-muted prose-li:text-lg
				prose-strong:text-white prose-strong:font-bold
				prose-a:text-primary prose-a:no-underline hover:prose-a:underline
				prose-img:rounded-2xl prose-img:border prose-img:border-white/10"
      >
        <Content />
      </div>

      <!-- Footer / Share -->
      <footer class="mt-20 pt-10 border-t border-white/5">
        <div
          class="flex flex-col md:flex-row items-center justify-between gap-8"
        >
          <div class="flex items-center gap-4">
            <span
              class="text-xs font-bold tracking-[0.2em] text-text-muted uppercase"
              >COMPARTIR:</span
            >
            <div class="flex gap-4">
              <!-- Mock share icons -->
              <div
                class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:border-primary hover:text-primary transition-all cursor-pointer"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"
                  ></path></svg
                >
              </div>
              <div
                class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:border-primary hover:text-primary transition-all cursor-pointer"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                  ></path></svg
                >
              </div>
            </div>
          </div>
          <a href="/blog" class="aggressive-btn !px-8 !py-3 !text-sm">
            VOLVER AL BLOG
          </a>
        </div>
      </footer>
    </div>
  </article>
</Layout>

<style>
  .font-heading {
    font-family: "Bebas Neue", sans-serif;
  }
  .font-subheading {
    font-family: "Space Grotesk", sans-serif;
  }
</style>
