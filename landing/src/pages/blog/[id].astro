---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { id: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="pt-32 pb-20 px-4 min-h-screen">
    <div class="max-w-3xl mx-auto">
      <!-- Back Button -->
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-text-muted hover:text-primary transition-colors font-bold tracking-widest text-xs uppercase group mb-6"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transform group-hover:-translate-x-1 transition-transform"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        VOLVER A TODOS LOS POSTS
      </a>

      <!-- Breadcrumbs -->
      <nav
        class="flex items-center gap-2 text-xs font-bold tracking-[0.2em] text-text-muted uppercase mb-8"
      >
        <a href="/" class="hover:text-primary transition-colors">INICIO</a>
        <span>/</span>
        <a href="/blog" class="hover:text-primary transition-colors">BLOG</a>
        <span>/</span>
        <span class="text-primary">{post.data.title}</span>
      </nav>

      <!-- Header -->
      <header class="mb-12 space-y-6">
        <div class="flex items-center flex-wrap gap-4">
          {
            post.data.tags.map((tag: string) => (
              <span class="text-[10px] tracking-[0.2em] font-bold text-primary uppercase bg-primary/10 px-3 py-1 rounded-full border border-primary/20">
                {tag}
              </span>
            ))
          }
          <time class="text-text-muted text-xs font-medium">
            {
              post.data.pubDate.toLocaleDateString("es-ES", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </time>
        </div>

        <h1
          class="text-5xl md:text-7xl font-heading italic text-white leading-[0.9] tracking-tighter"
        >
          {post.data.title}
        </h1>

        <p
          class="text-xl text-text-muted font-subheading leading-relaxed italic border-l-2 border-primary pl-6"
        >
          {post.data.description}
        </p>

        <div class="flex items-center gap-4 pt-4">
          <div
            class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-dark font-bold"
          >
            {post.data.author.charAt(0)}
          </div>
          <div>
            <p class="text-sm font-bold text-white uppercase tracking-wider">
              {post.data.author}
            </p>
            <p class="text-[10px] text-text-muted uppercase tracking-[0.2em]">
              EQUIPO CANCHA LIBRE
            </p>
          </div>
        </div>
      </header>

      <!-- Featured Image -->
      {
        post.data.image && (
          <div class="relative aspect-video rounded-3xl overflow-hidden mb-16 border border-white/5 shadow-2xl">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full h-full object-cover transition-image"
              style={`--transition-name: blog-image-${post.id}`}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark/50 to-transparent" />
          </div>
        )
      }

      <!-- Content -->
      <div
        class="prose prose-invert prose-primary max-w-none
				prose-headings:font-heading prose-headings:italic prose-headings:tracking-tight
				prose-h1:text-5xl prose-h2:text-4xl prose-h3:text-3xl
				prose-p:text-text-muted prose-p:text-lg prose-p:leading-relaxed
				prose-li:text-text-muted prose-li:text-lg
				prose-strong:text-white prose-strong:font-bold
				prose-a:text-primary prose-a:no-underline hover:prose-a:underline
				prose-img:rounded-2xl prose-img:border prose-img:border-white/10"
      >
        <Content />
      </div>

      <!-- Footer / Share -->
      <footer class="mt-20 pt-10 border-t border-white/5">
        <div
          class="flex flex-col md:flex-row items-center justify-between gap-8"
        >
          <div class="flex items-center gap-4">
            <span
              class="text-xs font-bold tracking-[0.2em] text-text-muted uppercase"
              >COMPARTIR:</span
            >
            <div class="flex gap-4">
              <!-- Instagram -->
              <button
                class="share-btn group w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:border-pink-500 hover:text-pink-500 transition-all cursor-pointer"
                data-platform="instagram"
                data-title={post.data.title}
                aria-label="Compartir en Instagram"
              >
                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                  <path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                  ></path>
                </svg>
              </button>

              <!-- Facebook -->
              <button
                class="share-btn group w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:border-blue-500 hover:text-blue-500 transition-all cursor-pointer"
                data-platform="facebook"
                aria-label="Compartir en Facebook"
              >
                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                  <path
                    d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"
                  ></path>
                </svg>
              </button>

              <!-- WhatsApp -->
              <button
                class="share-btn group w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:border-green-500 hover:text-green-500 transition-all cursor-pointer"
                data-platform="whatsapp"
                data-title={post.data.title}
                aria-label="Compartir en WhatsApp"
              >
                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                  <path
                    d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.876 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
                  ></path>
                </svg>
              </button>
            </div>
          </div>
          <a href="/blog" class="aggressive-btn !px-8 !py-3 !text-sm">
            VOLVER AL BLOG
          </a>
        </div>
      </footer>
    </div>
  </article>
</Layout>

<style>
  .font-heading {
    font-family: "Bebas Neue", sans-serif;
  }
  .font-subheading {
    font-family: "Space Grotesk", sans-serif;
  }
  @media (min-width: 768px) {
    .transition-image {
      view-transition-name: var(--transition-name);
    }
  }
</style>

<script is:inline>
  if (!window._shareSetupDone) {
    document.addEventListener('click', (e) => {
      // Event delegation para capturar el click en cualquier botón de compartir
      const btn = e.target.closest('.share-btn');
      if (!btn) return;
      
      e.preventDefault();
      
      const platform = btn.getAttribute('data-platform');
      const title = btn.getAttribute('data-title') || document.title;
      const url = window.location.href;
      const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
      
      // REQUERIMIENTO: En móvil, abrir las ventanas nativas (para cualquier botón)
      if (isMobile && navigator.share) {
        navigator.share({
          title: title,
          url: url
        }).catch(err => {
          if (err.name !== 'AbortError') console.error('Native share error:', err);
        });
        return;
      }
      
      // REQUERIMIENTO: Comportamiento en Desktop
      if (platform === 'facebook') {
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`, '_blank', 'width=600,height=400');
      } 
      else if (platform === 'whatsapp') {
        window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent(title + ' - ' + url)}`, '_blank');
      }
      else if (platform === 'instagram') {
        // En desktop solo copia el link para Instagram
        if (navigator.clipboard && window.isSecureContext) {
          navigator.clipboard.writeText(url).catch(err => console.error('Clipboard error:', err));
        } else {
          // Fallback para localhost sin HTTPS
          const textArea = document.createElement("textarea");
          textArea.value = url;
          textArea.style.position = "fixed";
          textArea.style.left = "-999999px";
          textArea.style.top = "-999999px";
          document.body.appendChild(textArea);
          textArea.focus();
          textArea.select();
          try { document.execCommand('copy'); } catch (err) {}
          textArea.remove();
        }
        
        // Mostrar toast diciendo "link copiado"
        const toast = document.createElement('div');
        toast.className = 'fixed bottom-8 right-8 bg-primary text-dark font-bold px-6 py-3 rounded-xl shadow-2xl transform translate-y-10 opacity-0 transition-all duration-300 z-50 flex items-center gap-2';
        toast.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>¡Link copiado!';
        document.body.appendChild(toast);
        
        void toast.offsetWidth; // Forzar reflow para la animación
        toast.classList.remove('translate-y-10', 'opacity-0');
        
        setTimeout(() => {
          toast.classList.add('translate-y-10', 'opacity-0');
          setTimeout(() => toast.remove(), 300);
        }, 3000);
      }
    });
    
    window._shareSetupDone = true;
  }
</script>
